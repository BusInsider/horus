{
  "name": "horus-cli",
  "version": "0.1.0",
  "description": "Kimi-native autonomous coding agent with sophisticated memory",
  "main": "dist/index.js",
  "bin": {
    "horus": "dist/cli-enhanced.js"
  },
  "scripts": {
    "build": "esbuild src/cli-enhanced.ts --bundle --platform=node --target=node20 --outfile=dist/cli-enhanced.js --format=cjs --external:better-sqlite3 --external:@xenova/transformers --external:sharp --external:onnxruntime-node --external:@modelcontextprotocol/sdk && sed -i '1{/^#!/d}' dist/cli-enhanced.js && sed -i '1i#!/usr/bin/env node' dist/cli-enhanced.js && chmod +x dist/cli-enhanced.js",
    "dev": "npm run build && node dist/cli.js",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "kimi",
    "coding",
    "memory"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^9.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "diff-match-patch": "^1.0.5",
    "fast-glob": "^3.3.2",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/bun": "^1.3.11",
    "@types/diff-match-patch": "^1.0.36",
    "@types/jest": "^30.0.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.20.0",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
